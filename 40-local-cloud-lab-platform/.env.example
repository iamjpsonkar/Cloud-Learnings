# Local Cloud Lab Platform — Environment Variables
#
# Copy this file to .env before running `make setup`
# cp .env.example .env
#
# All values here are fake/dev-only. Never use these in real environments.
# Do NOT commit .env to git — it is gitignored.

# ─────────────────────────────────────────────
# Platform Ports (change if default ports conflict)
# ─────────────────────────────────────────────
LAB_API_PORT=4567
LAB_UI_PORT=3001
TRAEFIK_DASHBOARD_PORT=8080

# ─────────────────────────────────────────────
# MinIO (S3-Compatible Object Storage)
# ─────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=labadmin
MINIO_ROOT_PASSWORD=labpassword123
MINIO_DEFAULT_BUCKET=lab-bucket

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=labdb
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpassword123

# ─────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────
MYSQL_PORT=3306
MYSQL_DATABASE=labdb
MYSQL_USER=labuser
MYSQL_PASSWORD=labpassword123
MYSQL_ROOT_PASSWORD=labrootpassword123

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGODB_PORT=27017
MONGODB_INITDB_ROOT_USERNAME=labadmin
MONGODB_INITDB_ROOT_PASSWORD=labpassword123
MONGODB_DATABASE=labdb

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=labpassword123

# ─────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=labuser
RABBITMQ_DEFAULT_PASS=labpassword123
RABBITMQ_DEFAULT_VHOST=labvhost

# ─────────────────────────────────────────────
# Redpanda (Kafka-compatible)
# ─────────────────────────────────────────────
REDPANDA_KAFKA_PORT=9092
REDPANDA_SCHEMA_REGISTRY_PORT=8081
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_PORT=8082

# ─────────────────────────────────────────────
# Vault (dev mode — auto-unsealed, tokens are fake)
# ─────────────────────────────────────────────
VAULT_PORT=8200
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token
VAULT_DEV_LISTEN_ADDRESS=0.0.0.0:8200

# ─────────────────────────────────────────────
# Keycloak
# ─────────────────────────────────────────────
KEYCLOAK_PORT=8888
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpassword123
KEYCLOAK_DB_VENDOR=h2

# ─────────────────────────────────────────────
# Prometheus
# ─────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=adminpassword123

# ─────────────────────────────────────────────
# Loki
# ─────────────────────────────────────────────
LOKI_PORT=3100

# ─────────────────────────────────────────────
# Jaeger
# ─────────────────────────────────────────────
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14268
JAEGER_GRPC_PORT=14250

# ─────────────────────────────────────────────
# OpenTelemetry Collector
# ─────────────────────────────────────────────
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# ─────────────────────────────────────────────
# Gitea
# ─────────────────────────────────────────────
GITEA_PORT=18080
GITEA_SSH_PORT=2222
GITEA_ADMIN_USER=labadmin
GITEA_ADMIN_PASSWORD=labpassword123
GITEA_ADMIN_EMAIL=lab@local.lab

# ─────────────────────────────────────────────
# Woodpecker CI
# ─────────────────────────────────────────────
WOODPECKER_PORT=18081
WOODPECKER_AGENT_SECRET=supersecretagentsecret123
WOODPECKER_GITEA_URL=http://gitea:3000
WOODPECKER_GITEA_CLIENT=woodpecker-oauth-client
WOODPECKER_GITEA_SECRET=woodpecker-oauth-secret

# ─────────────────────────────────────────────
# LocalStack (AWS emulator)
# ─────────────────────────────────────────────
LOCALSTACK_PORT=4566
LOCALSTACK_AUTH_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─────────────────────────────────────────────
# Azurite (Azure storage emulator)
# ─────────────────────────────────────────────
AZURITE_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002
# Azurite well-known dev connection string (always the same)
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;

# ─────────────────────────────────────────────
# Platform Internal
# ─────────────────────────────────────────────
# Log level for API: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to labs directory (relative to docker-compose.yml)
LABS_DIR=./labs

# SQLite database path (inside API container)
DB_PATH=/app/data/lab_platform.db

# Lab runner timeout in seconds
LAB_RUNNER_TIMEOUT=300

# Docker label used for all platform resources (do not change)
CLOUD_LAB_LABEL=com.cloudlabs.project=local-cloud-lab

# Docker network name
CLOUD_LAB_NETWORK=cloud-lab-network
