# =============================================================================
# Cloud-Learnings Lab Platform — Environment Variables
# =============================================================================
# Copy this file to .env before starting:
#   cp .env.example .env
#
# ALL CREDENTIALS HERE ARE FAKE AND LOCAL-ONLY.
# Never use real AWS/Azure/GCP credentials in this file.
# Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Project Identity
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=cloud-learnings-lab
LAB_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Resource Mode
# light   = only core services; safe for 4GB RAM
# medium  = core + data + one cloud emulator; needs 8GB RAM
# heavy   = all profiles; needs 16GB RAM
# -----------------------------------------------------------------------------
RESOURCE_MODE=light

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
HOMEPAGE_PORT=3000

# -----------------------------------------------------------------------------
# Traefik Reverse Proxy
# -----------------------------------------------------------------------------
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080

# -----------------------------------------------------------------------------
# Portainer (optional, opt-in)
# Enable only if you want Docker UI with socket access
# Set ENABLE_PORTAINER=true to add Portainer to the dashboard profile
# -----------------------------------------------------------------------------
ENABLE_PORTAINER=false
PORTAINER_PORT=9000

# -----------------------------------------------------------------------------
# Fake AWS Credentials (for LocalStack only — NOT real AWS)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_PORT=4566
LOCALSTACK_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Fake Azure Credentials (for Azurite only — NOT real Azure)
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=devstoreaccount1
AZURE_STORAGE_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;QueueEndpoint=http://localhost:10001/devstoreaccount1;TableEndpoint=http://localhost:10002/devstoreaccount1;
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# -----------------------------------------------------------------------------
# Fake GCP Credentials (for emulators only — NOT real GCP)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=local-dev-project
GCP_PUBSUB_EMULATOR_HOST=localhost:8085
GCP_FIRESTORE_EMULATOR_HOST=localhost:8086
PUBSUB_EMULATOR_PORT=8085
FIRESTORE_EMULATOR_PORT=8086

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9001
MINIO_CONSOLE_PORT=9002

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=labdb
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpassword123

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------
MYSQL_PORT=3306
MYSQL_DATABASE=labdb
MYSQL_USER=labuser
MYSQL_PASSWORD=labpassword123
MYSQL_ROOT_PASSWORD=rootpassword123

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpassword123
MONGO_INITDB_DATABASE=labdb

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=redispassword123

# -----------------------------------------------------------------------------
# Adminer (Database UI)
# -----------------------------------------------------------------------------
ADMINER_PORT=8081

# -----------------------------------------------------------------------------
# Redis Commander
# -----------------------------------------------------------------------------
REDIS_COMMANDER_PORT=8082

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=adminpassword123

# -----------------------------------------------------------------------------
# Redpanda (Kafka-compatible)
# -----------------------------------------------------------------------------
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_PORT=8083
REDPANDA_SCHEMA_REGISTRY_PORT=8084

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Loki
# -----------------------------------------------------------------------------
LOKI_PORT=3100

# -----------------------------------------------------------------------------
# Tempo
# -----------------------------------------------------------------------------
TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318

# -----------------------------------------------------------------------------
# OpenTelemetry Collector
# -----------------------------------------------------------------------------
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_PROMETHEUS_PORT=8889

# -----------------------------------------------------------------------------
# Vault (dev mode — NOT for production)
# -----------------------------------------------------------------------------
VAULT_PORT=8200
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token
VAULT_DEV_LISTEN_ADDRESS=0.0.0.0:8200

# -----------------------------------------------------------------------------
# Keycloak (identity and SSO)
# -----------------------------------------------------------------------------
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpassword123
KC_DB=dev-mem

# -----------------------------------------------------------------------------
# Gitea (local Git service)
# -----------------------------------------------------------------------------
GITEA_PORT=3002
GITEA_SSH_PORT=2222
GITEA_ADMIN_USER=gitadmin
GITEA_ADMIN_PASSWORD=gitpassword123
GITEA_ADMIN_EMAIL=gitadmin@local.dev

# -----------------------------------------------------------------------------
# Jenkins
# -----------------------------------------------------------------------------
JENKINS_PORT=8090
JENKINS_AGENT_PORT=50000

# -----------------------------------------------------------------------------
# Docker Registry (local)
# -----------------------------------------------------------------------------
REGISTRY_PORT=5000

# -----------------------------------------------------------------------------
# Sample Apps
# -----------------------------------------------------------------------------
SAMPLE_API_PORT=8000
SAMPLE_WORKER_REPLICAS=1
SAMPLE_FRONTEND_PORT=8100
EVENT_PRODUCER_PORT=8001
EVENT_CONSUMER_PORT=8002

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Set to true to enable optional heavy services
ENABLE_PORTAINER=false
ENABLE_DOCKER_REGISTRY=false
ENABLE_REDPANDA_CONSOLE=true

# Set resource limits (empty = no limit)
CONTAINER_MEMORY_LIMIT=
CONTAINER_CPU_LIMIT=
