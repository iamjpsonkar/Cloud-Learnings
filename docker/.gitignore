# =============================================================================
# Cloud-Learnings Lab Platform — .gitignore
# =============================================================================

# Environment variables (never commit real credentials)
.env
*.env.local
*.env.*.local

# Generated volumes and persistent data
data/backups/*.sql
data/backups/*.tar.gz
data/backups/*.dump
volumes/

# Reports output (generated at runtime)
reports/validations/*.json
reports/validations/*.html
reports/lab-results/*.json
reports/security-scans/*.json
reports/security-scans/*.sarif
reports/cost-analysis/*.csv
reports/troubleshooting/*.log

# Logs
*.log
logs/

# Terraform state and cache
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform.lock.hcl
infrastructure/opentofu/.terraform/
infrastructure/opentofu/*.tfstate
infrastructure/opentofu/*.tfstate.backup
infrastructure/opentofu/.terraform.lock.hcl
practice/**/.terraform/
practice/**/*.tfstate
practice/**/*.tfstate.backup
labs/**/.terraform/
labs/**/*.tfstate

# Kubernetes
infrastructure/kubernetes/secrets/*.yaml
labs/kubernetes-local/secrets.yaml

# SSH keys
*.pem
*.key
id_rsa
id_ed25519

# TLS certificates (generated locally)
configs/traefik/certs/
certs/
*.crt
*.cer

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Node.js
node_modules/
npm-debug.log

# Docker build artifacts
apps/**/build/
apps/**/__pycache__/

# Practice sandbox (user working space)
practice/sandbox/docker/*
practice/sandbox/terraform/*
practice/sandbox/kubernetes/*
practice/sandbox/ansible/*
practice/sandbox/experiments/*
# Keep placeholder READMEs
!practice/sandbox/docker/README.md
!practice/sandbox/terraform/README.md
!practice/sandbox/kubernetes/README.md
!practice/sandbox/ansible/README.md
!practice/sandbox/experiments/README.md

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Kind/k3d kubeconfig
kubeconfig
kubeconfig.yaml
.kube/
